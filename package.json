{
  "name": "meadtools-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:setup": "node scripts/dev-setup.mjs",
    "dev:setup:reset": "docker compose down -v && node scripts/dev-setup.mjs",
    "dev:web": "npm run dev --workspace @meadtools/web",
    "dev:mobile": "npm run start --workspace @meadtools/mobile",
    "mobile:android": "npm run android --workspace @meadtools/mobile",
    "mobile:ios": "npm run ios --workspace @meadtools/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @meadtools/mobile",
    "dev:i18n": "npm run dev:i18n --workspace @meadtools/web",
    "build": "npm run build --workspace @meadtools/web",
    "vercel-build": "npm run vercel-build --workspace @meadtools/web",
    "build:i18n": "npm run build:i18n --workspace @meadtools/web",
    "start": "npm run start --workspace @meadtools/web",
    "start:i18n": "npm run start:i18n --workspace @meadtools/web",
    "test": "npm run test:core && npm run test:schemas && npm run test:api-contract && npm run test:api-client && npm run test:brew-domain && npm test --workspace @meadtools/web",
    "typecheck": "npm run prisma:generate --workspace @meadtools/web && npm run typecheck --workspaces --if-present",
    "openapi:generate": "npm run openapi:generate --workspace @meadtools/web",
    "contracts:generate": "node scripts/generate-api-contract-types.mjs",
    "test:api-contract": "npm test --workspace @meadtools/api-contract",
    "test:api-client": "npm test --workspace @meadtools/api-client",
    "test:brew-domain": "npm test --workspace @meadtools/brew-domain",
    "test:core": "npm test --workspace @meadtools/core",
    "test:schemas": "npm test --workspace @meadtools/schemas",
    "lint": "npm run lint --workspace @meadtools/web",
    "check:unused-exports": "npm run check:unused-exports --workspace @meadtools/web",
    "check:package-boundaries": "node scripts/check-package-boundaries.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d && npm run db:push --workspace @meadtools/web && ALLOW_DB_RESET=true npm run db:seed --workspace @meadtools/web"
  }
}
